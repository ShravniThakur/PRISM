# --- Layer 1: Authentication Engine ---
# SQLAlchemy database URL (defaults to a local SQLite file)
DATABASE_URL=sqlite:///./prism_auth.db

# Fuzzy-hash verification thresholds (defaults shown)
TEXT_TLSH_MAX_DIFF=60
IMAGE_PHASH_MAX_HAMMING=10
VIDEO_FRAME_MAX_HAMMING=12
VIDEO_MIN_MATCH_RATIO=0.9
VIDEO_SAMPLE_FPS=1.0
